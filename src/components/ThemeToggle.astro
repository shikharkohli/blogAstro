---
import { Icon } from 'astro-icon/components';
---

<button class="theme-toggle" onclick="toggleTheme()" aria-label="Toggle dark mode">
	<Icon name="mdi:weather-sunny" class:list={['sun-icon']} />
	<Icon name="mdi:weather-night" class:list={['moon-icon']} />
</button>

<script is:inline>
	// Theme toggle function - initialization is handled in BaseHead.astro
	window.toggleTheme = function() {
		const html = document.documentElement;
		const currentTheme = html.getAttribute('data-theme');
		const newTheme = currentTheme === 'dark' ? 'light' : 'dark';
		
		html.setAttribute('data-theme', newTheme);
		localStorage.setItem('theme', newTheme);
		
		// Update aria-label for accessibility
		const toggleButtons = document.querySelectorAll('.theme-toggle');
		toggleButtons.forEach(button => {
			button.setAttribute('aria-label', newTheme === 'dark' ? 'Switch to light mode' : 'Switch to dark mode');
		});
	};

	// Set initial aria-labels when page loads
	document.addEventListener('DOMContentLoaded', function() {
		const currentTheme = document.documentElement.getAttribute('data-theme');
		const toggleButtons = document.querySelectorAll('.theme-toggle');
		toggleButtons.forEach(button => {
			button.setAttribute('aria-label', currentTheme === 'dark' ? 'Switch to light mode' : 'Switch to dark mode');
		});

		// Listen for system theme changes (only if user hasn't set a preference)
		window.matchMedia('(prefers-color-scheme: dark)').addEventListener('change', (e) => {
			if (!localStorage.getItem('theme')) {
				const newTheme = e.matches ? 'dark' : 'light';
				document.documentElement.setAttribute('data-theme', newTheme);
				
				// Update aria-labels
				toggleButtons.forEach(button => {
					button.setAttribute('aria-label', newTheme === 'dark' ? 'Switch to light mode' : 'Switch to dark mode');
				});
			}
		});
	});
</script>

<style>
	.theme-toggle {
		background: none;
		border: none;
		cursor: pointer;
		padding: 0.5rem;
		border-radius: 0.375rem;
		transition: background-color 0.2s ease;
		color: var(--nav-text);
		display: flex;
		align-items: center;
		justify-content: center;
		width: 2.5rem;
		height: 2.5rem;
		position: relative;
	}

	.theme-toggle:hover {
		background-color: rgba(var(--gray), 10%);
	}

	.theme-toggle:focus {
		outline: 2px solid var(--accent);
		outline-offset: 2px;
	}

	.sun-icon,
	.moon-icon {
		width: 1.25rem;
		height: 1.25rem;
		transition: opacity 0.3s ease, transform 0.3s ease;
		position: absolute;
	}

	/* Default (light mode) - show moon (to switch TO dark), hide sun */
	.moon-icon {
		opacity: 1;
		transform: scale(1) rotate(0deg);
	}

	.sun-icon {
		opacity: 0;
		transform: scale(0.8) rotate(180deg);
	}

	/* Dark mode - hide moon, show sun (to switch TO light) */
	:global([data-theme="dark"]) .theme-toggle .moon-icon {
		opacity: 0;
		transform: scale(0.8) rotate(-180deg);
	}

	:global([data-theme="dark"]) .theme-toggle .sun-icon {
		opacity: 1;
		transform: scale(1) rotate(0deg);
	}
</style>