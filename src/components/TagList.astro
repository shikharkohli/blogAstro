---
import { slugify } from '../utils/slugify';

interface Props {
	tags: string[];
	showLabel?: boolean;
	limit?: number;
}

const { tags, showLabel = false, limit } = Astro.props;
const displayTags = limit ? tags.slice(0, limit) : tags;
const hasMoreTags = limit && tags.length > limit;
---

<div class="tag-list">
	{showLabel && <span class="tag-label">Tags</span>}
	<ul class="tags">
		{displayTags.map((tag) => (
			<li class="tag">
				<a href={`/tags/${slugify(tag)}/`} class="tag-link">{tag}</a>
			</li>
		))}
		{hasMoreTags && (
			<li class="tag-more">+{tags.length - limit!} more</li>
		)}
	</ul>
</div>

<style>
	.tag-list {
		display: flex;
		align-items: center;
		gap: 10px;
		flex-wrap: wrap;
		margin: 8px 0;
	}
	.tag-label {
		font-size: 12px;
		letter-spacing: 0.1em;
		text-transform: uppercase;
		font-weight: 500;
		color: var(--fg-muted);
	}
	.tags {
		display: flex;
		flex-wrap: wrap;
		gap: 6px;
		list-style: none;
		margin: 0;
		padding: 0;
	}
	.tag { margin: 0; }
	.tag-link {
		display: inline-block;
		padding: 3px 10px;
		background: var(--bg-sunken);
		color: var(--fg-muted);
		text-decoration: none;
		border-radius: 99px;
		font-size: 12px;
		font-family: var(--font-mono);
		transition: background var(--dur-fast) var(--ease-out), color var(--dur-fast) var(--ease-out);
		border: 1px solid transparent;
	}
	.tag-link:hover {
		background: var(--accent-subtle);
		color: var(--accent-fg);
		text-decoration: none;
	}
	.tag-more {
		display: inline-block;
		padding: 3px 10px;
		color: var(--fg-subtle);
		font-size: 12px;
		font-family: var(--font-mono);
	}
</style>
