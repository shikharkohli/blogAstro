---
import { Icon } from 'astro-icon/components';
import { SITE_AUTHOR } from '../consts';

const GitHubIcon = `<svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M12 2C6.477 2 2 6.484 2 12.017c0 4.425 2.865 8.18 6.839 9.504.5.092.682-.217.682-.483 0-.237-.008-.868-.013-1.703-2.782.605-3.369-1.343-3.369-1.343-.454-1.158-1.11-1.466-1.11-1.466-.908-.62.069-.608.069-.608 1.003.07 1.531 1.032 1.531 1.032.892 1.53 2.341 1.088 2.91.832.092-.647.35-1.088.636-1.338-2.22-.253-4.555-1.113-4.555-4.951 0-1.093.39-1.988 1.029-2.688-.103-.253-.446-1.272.098-2.65 0 0 .84-.27 2.75 1.026A9.564 9.564 0 0112 6.844c.85.004 1.705.115 2.504.337 1.909-1.296 2.747-1.027 2.747-1.027.546 1.379.202 2.398.1 2.651.64.7 1.028 1.595 1.028 2.688 0 3.848-2.339 4.695-4.566 4.943.359.309.678.92.678 1.855 0 1.338-.012 2.419-.012 2.747 0 .268.18.58.688.482A10.019 10.019 0 0022 12.017C22 6.484 17.522 2 12 2z"/></svg>`;
const today = new Date();
---

<footer class="site-footer">
	<div class="footer-inner">
		<div class="footer-meta">
			<span class="copyright">&copy; {today.getFullYear()} {SITE_AUTHOR}</span>
			<span class="dot" aria-hidden="true"></span>
			<span class="tagline">Quiet writing on math, product, and systems.</span>
		</div>
		<div class="social-links" aria-label="Social links">
			<a href="https://github.com/shikharkohli" target="_blank" rel="noopener noreferrer" aria-label="GitHub">
				<Fragment set:html={GitHubIcon} />
			</a>
			<a href="https://www.linkedin.com/" target="_blank" rel="noopener noreferrer" aria-label="LinkedIn">
				<Icon name="mdi:linkedin" width={18} height={18} aria-hidden="true" />
			</a>
			<a href="mailto:shikharkohli@gmail.com" aria-label="Email">
				<Icon name="mdi:email" width={18} height={18} aria-hidden="true" />
			</a>
		</div>
	</div>
</footer>

<style>
	.site-footer {
		margin-top: 96px;
		border-top: 1px solid var(--border-subtle);
		background: var(--bg);
	}
	.footer-inner {
		max-width: 1100px;
		margin: 0 auto;
		padding: 48px 32px;
		display: flex;
		align-items: center;
		justify-content: space-between;
		gap: 24px;
	}
	.footer-meta {
		display: flex;
		align-items: center;
		gap: 12px;
		font-size: 13px;
		color: var(--fg-muted);
		font-family: var(--font-mono);
	}
	.copyright { font-variant-numeric: tabular-nums; }
	.dot {
		width: 3px;
		height: 3px;
		border-radius: 50%;
		background: var(--border-strong);
	}
	.tagline { font-family: var(--font-sans); }

	.social-links {
		display: flex;
		gap: 6px;
	}
	.social-links a {
		display: inline-flex;
		align-items: center;
		justify-content: center;
		width: 32px;
		height: 32px;
		color: var(--fg-muted);
		border-radius: var(--radius-sm);
		text-decoration: none;
		transition: color var(--dur-fast) var(--ease-out), background var(--dur-fast) var(--ease-out);
	}
	.social-links a:hover {
		color: var(--fg-strong);
		background: var(--bg-sunken);
	}

	@media (max-width: 720px) {
		.footer-inner {
			flex-direction: column;
			align-items: flex-start;
			padding: 32px 20px;
			gap: 16px;
		}
		.footer-meta { flex-wrap: wrap; }
	}
</style>
