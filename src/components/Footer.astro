---
import { Icon } from 'astro-icon/components';
import { SITE_AUTHOR } from '../consts';
const today = new Date();
---

<footer class="site-footer">
	<div class="footer-inner">
		<div class="footer-meta">
			<span class="copyright">&copy; {today.getFullYear()} {SITE_AUTHOR}</span>
			<span class="dot" aria-hidden="true"></span>
			<span class="tagline">Quiet writing on math, product, and systems.</span>
		</div>
		<div class="social-links" aria-label="Social links">
			<a href="https://github.com/shikharkohli" target="_blank" rel="noopener noreferrer" aria-label="GitHub">
				<Icon name="simple-icons:github" width={18} height={18} aria-hidden="true" />
			</a>
			<a href="https://www.linkedin.com/" target="_blank" rel="noopener noreferrer" aria-label="LinkedIn">
				<Icon name="mdi:linkedin" width={18} height={18} aria-hidden="true" />
			</a>
			<a href="mailto:shikharkohli@gmail.com" aria-label="Email">
				<Icon name="mdi:email" width={18} height={18} aria-hidden="true" />
			</a>
		</div>
	</div>
</footer>

<style>
	.site-footer {
		margin-top: 96px;
		border-top: 1px solid var(--border-subtle);
		background: var(--bg);
	}
	.footer-inner {
		max-width: 1100px;
		margin: 0 auto;
		padding: 48px 32px;
		display: flex;
		align-items: center;
		justify-content: space-between;
		gap: 24px;
	}
	.footer-meta {
		display: flex;
		align-items: center;
		gap: 12px;
		font-size: 13px;
		color: var(--fg-muted);
		font-family: var(--font-mono);
	}
	.copyright { font-variant-numeric: tabular-nums; }
	.dot {
		width: 3px;
		height: 3px;
		border-radius: 50%;
		background: var(--border-strong);
	}
	.tagline { font-family: var(--font-sans); }

	.social-links {
		display: flex;
		gap: 6px;
	}
	.social-links a {
		display: inline-flex;
		align-items: center;
		justify-content: center;
		width: 32px;
		height: 32px;
		color: var(--fg-muted);
		border-radius: var(--radius-sm);
		text-decoration: none;
		transition: color var(--dur-fast) var(--ease-out), background var(--dur-fast) var(--ease-out);
	}
	.social-links a:hover {
		color: var(--fg-strong);
		background: var(--bg-sunken);
	}

	@media (max-width: 720px) {
		.footer-inner {
			flex-direction: column;
			align-items: flex-start;
			padding: 32px 20px;
			gap: 16px;
		}
		.footer-meta { flex-wrap: wrap; }
	}
</style>
