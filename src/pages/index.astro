---
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';
import { SITE_DESCRIPTION, SITE_TITLE } from '../consts';
import { getCollection } from 'astro:content';
import FormattedDate from '../components/FormattedDate.astro';

const posts = (await getCollection('blog'))
	.sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
	.slice(0, 4);
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
	</head>
	<body>
		<Header />
		<main id="main">
			<section class="hero">
				<div class="eyebrow">Vibes and Variance</div>
				<h1>Quiet writing on math, product, and the systems behind how we think.</h1>
				<p>I'm Shikhar — I write essays about the ideas that keep me up at night: abstract patterns, strategic behavior, the craft of building products, and the uncomfortable edges of data.</p>
				<div class="hero-meta">
					<a href="/blog" class="cta">Read the writing →</a>
					<span class="dot" aria-hidden="true"></span>
					<a href="/about" class="meta-link">About</a>
				</div>
			</section>

			<section>
				<header class="section-head">
					<h2>Recent writing</h2>
					<a href="/blog" class="see-all">All posts →</a>
				</header>
				<div class="post-list">
					{posts.map((post) => (
						<a class="post-row" href={`/blog/${post.id}/`}>
							<div class="post-date"><FormattedDate date={post.data.pubDate} /></div>
							<div>
								<h3 class="post-title">{post.data.title}</h3>
								{post.data.description && <p class="post-desc">{post.data.description}</p>}
							</div>
							<div class="post-read">Read →</div>
						</a>
					))}
				</div>
			</section>

			<section>
				<header class="section-head">
					<h2>What captures my curiosity</h2>
				</header>
				<div class="note-grid">
					<article class="note-card">
						<div class="date">Field 01</div>
						<h3>Mathematics</h3>
						<p>Abstract patterns, logic, and the elegant structures underlying reality.</p>
					</article>
					<article class="note-card">
						<div class="date">Field 02</div>
						<h3>Programming</h3>
						<p>Building tools, problem-solving through code, and software design.</p>
					</article>
					<article class="note-card">
						<div class="date">Field 03</div>
						<h3>Product</h3>
						<p>Creating meaningful products, user needs, and business strategy.</p>
					</article>
					<article class="note-card">
						<div class="date">Field 04</div>
						<h3>Game Theory</h3>
						<p>Strategic interactions, cooperation, competition, and rational choice.</p>
					</article>
				</div>
			</section>
		</main>
		<Footer />
	</body>
</html>

<style>
	main {
		max-width: 1100px;
		margin: 0 auto;
		padding: 0 32px;
	}

	/* --- hero --- */
	.hero {
		padding: 96px 0 80px;
		max-width: 720px;
	}
	.eyebrow {
		font-size: 12px;
		letter-spacing: 0.1em;
		text-transform: uppercase;
		font-weight: 500;
		color: var(--fg-muted);
		margin-bottom: 16px;
	}
	.hero h1 {
		font-size: 56px;
		line-height: 1.1;
		letter-spacing: -0.025em;
		font-weight: 600;
		color: var(--fg-strong);
		margin: 0 0 24px;
		text-wrap: balance;
	}
	.hero p {
		font-size: 19px;
		line-height: 1.6;
		color: var(--fg-muted);
		margin: 0 0 28px;
		max-width: 60ch;
	}
	.hero-meta {
		display: flex;
		gap: 16px;
		align-items: center;
		font-size: 14px;
		color: var(--fg-muted);
	}
	.hero-meta .dot {
		width: 3px;
		height: 3px;
		border-radius: 50%;
		background: var(--border-strong);
	}
	.cta {
		color: var(--fg-strong);
		font-weight: 500;
		border-bottom: 1px solid var(--accent);
		padding-bottom: 2px;
		text-decoration: none;
	}
	.cta:hover { color: var(--accent-fg); }
	.meta-link { color: var(--fg-muted); text-decoration: none; }
	.meta-link:hover { color: var(--fg-strong); }

	/* --- section head --- */
	.section-head {
		display: flex;
		align-items: baseline;
		justify-content: space-between;
		padding: 40px 0 24px;
		border-top: 1px solid var(--border-subtle);
	}
	.section-head h2 {
		font-size: 22px;
		font-weight: 600;
		letter-spacing: -0.01em;
		color: var(--fg-strong);
		margin: 0;
	}
	.see-all {
		font-size: 13px;
		color: var(--fg-muted);
		text-decoration: none;
	}
	.see-all:hover { color: var(--accent-fg); }

	/* --- post list --- */
	.post-list { display: flex; flex-direction: column; }
	.post-row {
		display: grid;
		grid-template-columns: 110px 1fr 80px;
		gap: 24px;
		align-items: baseline;
		padding: 20px 12px;
		border-bottom: 1px solid var(--border-subtle);
		transition: background 150ms var(--ease-out);
		margin: 0 -12px;
		border-radius: 4px;
		text-decoration: none;
		color: inherit;
	}
	.post-row:hover { background: var(--bg-sunken); text-decoration: none; }
	.post-date {
		font-size: 13px;
		font-family: var(--font-mono);
		color: var(--fg-muted);
		white-space: nowrap;
	}
	.post-title {
		font-size: 17px;
		font-weight: 500;
		color: var(--fg-strong);
		letter-spacing: -0.005em;
		margin: 0 0 4px;
	}
	.post-desc {
		font-size: 14px;
		color: var(--fg-muted);
		line-height: 1.55;
		margin: 0;
	}
	.post-read {
		font-size: 12px;
		color: var(--fg-subtle);
		text-align: right;
		font-variant-numeric: tabular-nums;
	}

	/* --- note grid --- */
	.note-grid {
		display: grid;
		grid-template-columns: repeat(4, 1fr);
		gap: 14px;
	}
	.note-card {
		background: var(--bg-raised);
		border: 1px solid var(--border);
		border-radius: 6px;
		padding: 18px;
		transition: transform 180ms var(--ease-out), box-shadow 180ms var(--ease-out);
	}
	.note-card:hover {
		transform: translateY(-1px);
		box-shadow: var(--shadow-md);
	}
	.note-card .date {
		font-size: 11px;
		letter-spacing: 0.08em;
		text-transform: uppercase;
		color: var(--fg-muted);
		font-weight: 500;
		margin-bottom: 10px;
		font-family: var(--font-mono);
	}
	.note-card h3 {
		font-size: 15px;
		font-weight: 600;
		color: var(--fg-strong);
		margin: 0 0 6px;
		letter-spacing: -0.005em;
	}
	.note-card p {
		font-size: 13px;
		color: var(--fg-muted);
		margin: 0;
		line-height: 1.55;
	}

	@media (max-width: 900px) {
		.note-grid { grid-template-columns: 1fr 1fr; }
	}

	@media (max-width: 720px) {
		main { padding: 0 20px; }
		.hero { padding: 56px 0 48px; }
		.hero h1 { font-size: 36px; }
		.hero p { font-size: 17px; }
		.post-row {
			grid-template-columns: 1fr;
			gap: 6px;
		}
		.post-read { display: none; }
		.note-grid { grid-template-columns: 1fr; }
	}
</style>
