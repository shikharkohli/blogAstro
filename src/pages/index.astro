---
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';
import { SITE_DESCRIPTION, SITE_TITLE } from '../consts';
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
	</head>
	<body>
		<Header />
		<main id="main">
			<!-- Hero Section -->
			<section class="hero-section">
				<div class="hero-content">
					<div class="profile-container">
						<div class="profile-photo-wrapper">
							<div class="profile-photo-placeholder">S K</div>
						</div>
					</div>
					<div class="intro-content">
						<h1>Hello! I'm Shikhar K</h1>
						<p>Welcome to <strong>Wanderings</strong>, a space for exploring the intersection of math, programming, product thinking, psychology, and game theory. I write about ideas that fascinate me and hope they might fascinate you too.</p>
					</div>
				</div>
			</section>

			<!-- Interests Section -->
			<section class="interests-section">
				<h2>What Captures My Curiosity</h2>
				<div class="interests-grid">
					<article class="interest-card">
						<h3>Mathematics</h3>
						<p>Exploring abstract patterns, logic, and the elegant structures underlying reality.</p>
					</article>
					<article class="interest-card">
						<h3>Programming</h3>
						<p>Building tools and systems, problem-solving through code, and software design.</p>
					</article>
					<article class="interest-card">
						<h3>Product Management</h3>
						<p>Creating meaningful products, understanding user needs, and business strategy.</p>
					</article>
					<article class="interest-card">
						<h3>Psychology</h3>
						<p>Understanding human behavior, decision-making, and what drives us.</p>
					</article>
					<article class="interest-card">
						<h3>Game Theory</h3>
						<p>Strategic interactions, cooperation, competition, and rational choice.</p>
					</article>
				</div>
			</section>

			<!-- Blog Expectations Section -->
			<section class="blog-expectations-section">
				<h2>What You'll Find Here</h2>
				<p>This blog features personal essays and thoughts on the topics above. Rather than quick takes, you'll find deeper explorations of ideas that I'm working through. Topics range from technical deep-dives and product case studies to broader thoughts on human behavior and strategic thinking.</p>
				<p>I aim for thoughtful, nuanced writing that respects your time and intelligence. Whether you're here for a specific topic or just browsing, I hope you find something that sparks your curiosity.</p>
			</section>

			<!-- Call-to-Action -->
			<section class="cta-section">
				<a href="/blog" class="cta-button">Explore the Blog →</a>
			</section>
		</main>
		<Footer />
	</body>
</html>

<style>
	/* Hero Section */
	.hero-section {
		margin-bottom: 4rem;
	}

	.hero-content {
		display: flex;
		gap: 2rem;
		align-items: center;
	}

	.profile-container {
		flex-shrink: 0;
	}

	.profile-photo-wrapper {
		animation: float 3s ease-in-out infinite;
	}

	.profile-photo-placeholder {
		display: flex;
		align-items: center;
		justify-content: center;
		width: 200px;
		height: 200px;
		border-radius: 50%;
		background: linear-gradient(135deg, var(--accent), rgba(35, 55, 255, 0.7));
		color: white;
		font-size: 3rem;
		font-weight: 700;
		letter-spacing: 0.5em;
		box-shadow: 0 10px 30px rgba(35, 55, 255, 0.2);
	}

	.intro-content h1 {
		margin-top: 0;
		font-size: 2.5rem;
	}

	.intro-content p {
		line-height: 1.7;
		font-size: 1.1rem;
	}

	/* Interests Section */
	.interests-section {
		margin-bottom: 4rem;
	}

	.interests-section h2 {
		margin-bottom: 2rem;
	}

	.interests-grid {
		display: grid;
		grid-template-columns: 1fr 1fr;
		gap: 1.5rem;
		margin-bottom: 2rem;
	}

	.interest-card {
		padding: 1.5rem;
		border-radius: 8px;
		background: rgba(35, 55, 255, 0.05);
		border: 1px solid rgba(35, 55, 255, 0.1);
		transition: transform 0.2s ease, box-shadow 0.2s ease;
	}

	.interest-card:hover {
		transform: translateY(-4px);
		box-shadow: 0 8px 20px rgba(35, 55, 255, 0.15);
	}

	.interest-card h3 {
		margin-top: 0;
		margin-bottom: 0.5rem;
		color: var(--accent);
		font-size: 1.25rem;
	}

	.interest-card p {
		margin: 0;
		font-size: 0.95rem;
		color: var(--text-color);
		line-height: 1.6;
	}

	/* Blog Expectations Section */
	.blog-expectations-section {
		margin-bottom: 3rem;
	}

	.blog-expectations-section p {
		line-height: 1.8;
		margin-bottom: 1rem;
	}

	/* Call-to-Action */
	.cta-section {
		text-align: center;
		margin-top: 4rem;
		padding-top: 2rem;
		border-top: 1px solid rgba(35, 55, 255, 0.1);
	}

	.cta-button {
		display: inline-block;
		padding: 0.75rem 1.5rem;
		background: var(--accent);
		color: white;
		text-decoration: none;
		border-radius: 6px;
		font-weight: 600;
		transition: transform 0.2s ease, box-shadow 0.2s ease;
	}

	.cta-button:hover {
		transform: scale(1.05);
		box-shadow: 0 6px 20px rgba(35, 55, 255, 0.3);
	}

	/* Animation */
	@keyframes float {
		0%, 100% {
			transform: translateY(0px);
		}
		50% {
			transform: translateY(-20px);
		}
	}

	/* Dark Mode Adjustments */
	html[data-theme='dark'] .profile-photo-placeholder {
		background: linear-gradient(135deg, #46e856, rgba(70, 232, 86, 0.7));
		box-shadow: 0 10px 30px rgba(70, 232, 86, 0.2);
	}

	html[data-theme='dark'] .interest-card {
		background: rgba(70, 232, 86, 0.05);
		border-color: rgba(70, 232, 86, 0.1);
	}

	html[data-theme='dark'] .interest-card:hover {
		box-shadow: 0 8px 20px rgba(70, 232, 86, 0.15);
	}

	html[data-theme='dark'] .interest-card h3 {
		color: #46e856;
	}

	html[data-theme='dark'] .blog-expectations-section,
	html[data-theme='dark'] .cta-section {
		border-color: rgba(70, 232, 86, 0.1);
	}

	html[data-theme='dark'] .cta-button {
		background: #46e856;
		color: #1a1a1a;
	}

	html[data-theme='dark'] .cta-button:hover {
		box-shadow: 0 6px 20px rgba(70, 232, 86, 0.3);
	}

	/* Responsive Design */
	@media (max-width: 720px) {
		.hero-content {
			flex-direction: column;
			align-items: center;
			text-align: center;
			gap: 1.5rem;
		}

		.profile-photo-placeholder {
			width: 150px;
			height: 150px;
			font-size: 2rem;
		}

		.intro-content h1 {
			font-size: 1.75rem;
		}

		.intro-content p {
			font-size: 1rem;
		}

		.interests-grid {
			grid-template-columns: 1fr;
			gap: 1rem;
		}

		.interest-card {
			padding: 1.25rem;
		}

		.interest-card h3 {
			font-size: 1.1rem;
		}

		.interest-card p {
			font-size: 0.9rem;
		}

		.interests-section,
		.blog-expectations-section {
			margin-bottom: 2rem;
		}

		.cta-section {
			margin-top: 2rem;
		}
	}
</style>
