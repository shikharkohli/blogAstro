---
import { getCollection } from 'astro:content';
import BaseHead from '../../components/BaseHead.astro';
import Footer from '../../components/Footer.astro';
import Header from '../../components/Header.astro';
import { SITE_TITLE } from '../../consts';
import { slugify } from '../../utils/slugify';

const allPosts = await getCollection('blog');

const tagCounts = allPosts.reduce((acc, post) => {
	post.data.tags.forEach((tag) => {
		acc[tag] = (acc[tag] || 0) + 1;
	});
	return acc;
}, {} as Record<string, number>);

const sortedTags = Object.entries(tagCounts).sort(([a, countA], [b, countB]) => {
	const numA = countA as number;
	const numB = countB as number;
	if (numB !== numA) return numB - numA;
	return a.localeCompare(b);
});
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={`Tags — ${SITE_TITLE}`} description="Browse posts by tag" />
	</head>
	<body>
		<Header />
		<main id="main">
			<section class="page-hero">
				<div class="eyebrow">Tags</div>
				<h1>Browse by topic.</h1>
				<p>Every tag, ranked by how often it's shown up. <a href="/blog">← Back to writing</a></p>
			</section>

			<div class="tag-grid">
				{sortedTags.map(([tag, count]) => (
					<a href={`/tags/${slugify(tag)}/`} class="tag-card">
						<div class="tag-count">{count} {count === 1 ? 'post' : 'posts'}</div>
						<div class="tag-name">{tag}</div>
					</a>
				))}
			</div>
		</main>
		<Footer />
	</body>
</html>

<style>
	main { max-width: 1100px; margin: 0 auto; padding: 0 32px; }
	.page-hero { padding: 72px 0 48px; max-width: 720px; }
	.eyebrow {
		font-size: 12px; letter-spacing: 0.1em; text-transform: uppercase;
		font-weight: 500; color: var(--fg-muted); margin-bottom: 16px;
	}
	.page-hero h1 {
		font-size: 48px; line-height: 1.1; letter-spacing: -0.025em;
		font-weight: 600; color: var(--fg-strong); margin: 0 0 16px;
	}
	.page-hero p { font-size: 17px; color: var(--fg-muted); margin: 0; }
	.page-hero a { color: var(--fg-muted); text-decoration: none; border-bottom: 1px solid var(--border-strong); }
	.page-hero a:hover { color: var(--fg-strong); }

	.tag-grid {
		display: grid;
		grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
		gap: 12px;
		padding-bottom: 64px;
	}
	.tag-card {
		display: flex;
		flex-direction: column;
		gap: 6px;
		padding: 16px 18px;
		background: var(--bg-raised);
		border: 1px solid var(--border);
		border-radius: 6px;
		text-decoration: none;
		color: inherit;
		transition: transform 180ms var(--ease-out), box-shadow 180ms var(--ease-out), border-color 180ms var(--ease-out);
	}
	.tag-card:hover {
		transform: translateY(-1px);
		box-shadow: var(--shadow-md);
		border-color: var(--border-strong);
		text-decoration: none;
	}
	.tag-count {
		font-size: 11px;
		letter-spacing: 0.08em;
		text-transform: uppercase;
		color: var(--fg-muted);
		font-family: var(--font-mono);
		font-weight: 500;
	}
	.tag-name {
		font-size: 16px;
		font-weight: 600;
		color: var(--fg-strong);
		letter-spacing: -0.005em;
	}

	@media (max-width: 720px) {
		main { padding: 0 20px; }
		.page-hero { padding: 48px 0 32px; }
		.page-hero h1 { font-size: 32px; }
		.tag-grid { grid-template-columns: 1fr 1fr; }
	}
	@media (max-width: 420px) {
		.tag-grid { grid-template-columns: 1fr; }
	}
</style>
