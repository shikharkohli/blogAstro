---
import { getCollection } from 'astro:content';
import BaseHead from '../../components/BaseHead.astro';
import Footer from '../../components/Footer.astro';
import FormattedDate from '../../components/FormattedDate.astro';
import Header from '../../components/Header.astro';
import { SITE_TITLE } from '../../consts';
import { slugify } from '../../utils/slugify';

export async function getStaticPaths() {
	const allPosts = await getCollection('blog');
	const uniqueTags = [...new Set(allPosts.flatMap((post) => post.data.tags))];

	return uniqueTags.map((tag) => {
		const filteredPosts = allPosts
			.filter((post) => post.data.tags.includes(tag))
			.sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());

		return {
			params: { tag: slugify(tag) },
			props: { posts: filteredPosts, tagName: tag },
		};
	});
}

const { posts, tagName } = Astro.props;
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={`Tag: ${tagName} — ${SITE_TITLE}`} description={`Posts tagged with "${tagName}"`} />
	</head>
	<body>
		<Header />
		<main id="main">
			<section class="page-hero">
				<div class="eyebrow">Tag · {posts.length} {posts.length === 1 ? 'post' : 'posts'}</div>
				<h1>{tagName}</h1>
				<p><a href="/tags">← All tags</a></p>
			</section>

			<div class="post-list">
				{posts.map((post) => (
					<a class="post-row" href={`/blog/${post.id}/`}>
						<div class="post-date"><FormattedDate date={post.data.pubDate} /></div>
						<div>
							<h3 class="post-title">{post.data.title}</h3>
							{post.data.description && <p class="post-desc">{post.data.description}</p>}
						</div>
						<div class="post-read">Read →</div>
					</a>
				))}
			</div>
		</main>
		<Footer />
	</body>
</html>

<style>
	main { max-width: 1100px; margin: 0 auto; padding: 0 32px; }
	.page-hero { padding: 72px 0 48px; max-width: 720px; }
	.eyebrow {
		font-size: 12px; letter-spacing: 0.1em; text-transform: uppercase;
		font-weight: 500; color: var(--fg-muted); margin-bottom: 16px;
	}
	.page-hero h1 {
		font-size: 48px; line-height: 1.1; letter-spacing: -0.025em;
		font-weight: 600; color: var(--fg-strong); margin: 0 0 16px;
	}
	.page-hero p { font-size: 15px; color: var(--fg-muted); margin: 0; }
	.page-hero a { color: var(--fg-muted); text-decoration: none; border-bottom: 1px solid var(--border-strong); }
	.page-hero a:hover { color: var(--fg-strong); }

	.post-list { display: flex; flex-direction: column; border-top: 1px solid var(--border-subtle); }
	.post-row {
		display: grid; grid-template-columns: 110px 1fr 80px; gap: 24px;
		align-items: baseline; padding: 22px 12px;
		border-bottom: 1px solid var(--border-subtle);
		transition: background 150ms var(--ease-out);
		margin: 0 -12px; border-radius: 4px;
		text-decoration: none; color: inherit;
	}
	.post-row:hover { background: var(--bg-sunken); text-decoration: none; }
	.post-date { font-size: 13px; font-family: var(--font-mono); color: var(--fg-muted); white-space: nowrap; }
	.post-title { font-size: 18px; font-weight: 500; color: var(--fg-strong); letter-spacing: -0.005em; margin: 0 0 4px; }
	.post-desc { font-size: 14px; color: var(--fg-muted); line-height: 1.55; margin: 0; }
	.post-read { font-size: 12px; color: var(--fg-subtle); text-align: right; font-variant-numeric: tabular-nums; }

	@media (max-width: 720px) {
		main { padding: 0 20px; }
		.page-hero { padding: 48px 0 32px; }
		.page-hero h1 { font-size: 32px; }
		.post-row { grid-template-columns: 1fr; gap: 6px; }
		.post-read { display: none; }
	}
</style>
