---
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';
import { SITE_TITLE } from '../consts';
import { projects } from '../data/portfolio';

const pageTitle = `Work — ${SITE_TITLE}`;
const pageDescription = 'Projects — product work, technical builds, and open-source contributions.';
const sorted = projects.sort((a, b) => a.order - b.order);
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={pageTitle} description={pageDescription} />
	</head>
	<body>
		<Header />
		<main id="main">
			<section class="page-hero">
				<div class="eyebrow">Work</div>
				<h1>Things I've built and shipped.</h1>
				<p>A selection of projects — product, technical, and everything in between. Each one was a chance to solve a real problem and learn something sideways.</p>
			</section>

			<div class="project-list">
				{sorted.map((project) => (
					<article class="project-row">
						<div class="project-index">{String(project.order).padStart(2, '0')}</div>
						<div class="project-body">
							<h2 class="project-title">{project.title}</h2>
							<p class="project-desc">{project.description}</p>

							{project.skills.length > 0 && (
								<div class="skills">
									{project.skills.map((skill) => (
										<span class="skill-tag">{skill}</span>
									))}
								</div>
							)}

							{project.impact && (
								<div class="impact">
									<span class="impact-metric">{project.impact.metric}</span>
									<span class="impact-sep" aria-hidden="true">·</span>
									<span class="impact-description">{project.impact.description}</span>
								</div>
							)}

							{(project.links.github || project.links.demo || project.links.website) && (
								<div class="project-links">
									{project.links.github && (
										<a href={project.links.github} target="_blank" rel="noopener noreferrer">GitHub →</a>
									)}
									{project.links.demo && (
										<a href={project.links.demo} target="_blank" rel="noopener noreferrer">Demo →</a>
									)}
									{project.links.website && (
										<a href={project.links.website} target="_blank" rel="noopener noreferrer">Website →</a>
									)}
								</div>
							)}
						</div>
					</article>
				))}
			</div>
		</main>
		<Footer />
	</body>
</html>

<style>
	main { max-width: 1100px; margin: 0 auto; padding: 0 32px; }
	.page-hero { padding: 72px 0 56px; max-width: 720px; }
	.eyebrow {
		font-size: 12px; letter-spacing: 0.1em; text-transform: uppercase;
		font-weight: 500; color: var(--fg-muted); margin-bottom: 16px;
	}
	.page-hero h1 {
		font-size: 48px; line-height: 1.1; letter-spacing: -0.025em;
		font-weight: 600; color: var(--fg-strong); margin: 0 0 20px; text-wrap: balance;
	}
	.page-hero p { font-size: 18px; line-height: 1.6; color: var(--fg-muted); margin: 0; max-width: 60ch; }

	.project-list {
		display: flex;
		flex-direction: column;
		border-top: 1px solid var(--border-subtle);
	}
	.project-row {
		display: grid;
		grid-template-columns: 60px 1fr;
		gap: 32px;
		padding: 36px 0;
		border-bottom: 1px solid var(--border-subtle);
		align-items: start;
	}
	.project-index {
		font-family: var(--font-mono);
		font-size: 13px;
		color: var(--fg-subtle);
		padding-top: 4px;
	}
	.project-title {
		font-size: 22px;
		font-weight: 600;
		letter-spacing: -0.01em;
		color: var(--fg-strong);
		margin: 0 0 8px;
	}
	.project-desc {
		font-size: 16px;
		line-height: 1.6;
		color: var(--fg-muted);
		margin: 0 0 16px;
		max-width: 62ch;
	}
	.skills { display: flex; flex-wrap: wrap; gap: 6px; margin-bottom: 14px; }
	.skill-tag {
		font-size: 12px;
		color: var(--fg-muted);
		background: var(--bg-sunken);
		padding: 3px 9px;
		border-radius: 99px;
		font-family: var(--font-mono);
	}
	.impact {
		font-size: 13px;
		color: var(--fg-muted);
		margin-bottom: 14px;
	}
	.impact-metric { color: var(--fg-strong); font-weight: 500; }
	.impact-sep { margin: 0 8px; color: var(--border-strong); }
	.project-links { display: flex; gap: 20px; }
	.project-links a {
		font-size: 14px;
		color: var(--accent-fg);
		text-decoration: none;
		border-bottom: 1px solid transparent;
	}
	.project-links a:hover { border-bottom-color: var(--accent); }

	@media (max-width: 720px) {
		main { padding: 0 20px; }
		.page-hero { padding: 48px 0 32px; }
		.page-hero h1 { font-size: 32px; }
		.project-row { grid-template-columns: 1fr; gap: 8px; padding: 28px 0; }
		.project-index { font-size: 12px; }
	}
</style>
